# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# ── Grafana admin credentials ─────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=change-me

# ── MetroVision API ───────────────────────────────────────────────────
# Raw value of an API key. Its SHA-256 must also be added to .api-keys.
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
METROVISION_API_KEY=replace-with-a-random-token

# ── MLflow basic auth ─────────────────────────────────────────────────
# Default admin bootstrapped from monitoring/mlflow_basic_auth.ini on
# the first server start. Password must be ≥ 13 characters.
# Rotate via the MLflow auth API for production.
MLFLOW_TRACKING_USERNAME=admin
MLFLOW_TRACKING_PASSWORD=change-me-and-make-it-long

# Used by MLflow basic-auth for CSRF protection. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
MLFLOW_FLASK_SERVER_SECRET_KEY=replace-me-with-a-real-secret

# ── Postgres backing the MLflow tracking server (phase 6.1) ───────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_MLFLOW_PASSWORD=replace-me-with-a-real-password

# ── MinIO holding MLflow artefacts (phase 6.2) ────────────────────────
# Root credentials; rotate via the MinIO console after first start.
MINIO_ROOT_USER=metrovision
MINIO_ROOT_PASSWORD=replace-me-with-a-real-password
